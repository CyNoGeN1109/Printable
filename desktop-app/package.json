{
  "name": "printable",
  "version": "1.1.0",
  "description": "Printable Vendor — complete operating software for print shops",
  "author": "Printable",
  "main": "dist-electron/main/index.js",
  "scripts": {
    "postinstall": "node scripts/download-mupdf.js",
    "dev": "vite",
    "build": "tsc && vite build && electron-builder",
    "build:win": "tsc && vite build && electron-builder --win",
    "lint": "eslint src --ext ts,tsx",
    "preview": "vite preview"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "dotenv": "^17.4.2",
    "electron-updater": "^6.8.3",
    "net-snmp": "^3.26.3",
    "pdf-to-printer": "^5.7.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^5.57.1",
    "@typescript-eslint/parser": "^5.57.1",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.16",
    "concurrently": "^9.2.1",
    "electron": "^24.8.8",
    "electron-builder": "^24.13.3",
    "eslint": "^8.38.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.3.4",
    "postcss": "^8.4.32",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwindcss": "^3.3.6",
    "typescript": "^5.9.3",
    "vite": "^4.5.14",
    "vite-plugin-electron": "^0.11.2",
    "vite-plugin-electron-renderer": "^0.14.5"
  },
  "build": {
    "appId": "com.printable.app.v2",
    "productName": "Printable Vendor",
    "asar": true,
    "files": [
      "dist",
      "dist-electron"
    ],
    "asarUnpack": [
      "**/node_modules/pdf-to-printer/dist/*.exe"
    ],
    "extraResources": [
      {
        "from": "mupdf",
        "to": "mupdf",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "artifactName": "Printable_Setup.exe"
    },
    "directories": {
      "output": "dist_working"
    }
  }
}
